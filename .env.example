# Database
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/satisfactory_planner

# Optional: separate test database URL (falls back to DATABASE_URL if unset)
DATABASE_URL_TEST=postgresql://postgres:password@localhost:5432/satisfactory_planner_test

# Auth.js (NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# OAuth Providers (add as needed)
# AUTH_GITHUB_ID=your-github-client-id
# AUTH_GITHUB_SECRET=your-github-client-secret

# App
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
